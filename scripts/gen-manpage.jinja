#!/usr/bin/env bash
set -euo pipefail

# Always build the binary to ensure it's for the current platform
echo "Building {{ package_name }}..."
./scripts/build

# Create man directory
mkdir -p man/man1

# Generate man page
echo "Generating man page..."
./{{ package_name }} man > man/man1/{{ package_name }}.1 || {
    echo "Note: 'man' subcommand not implemented yet"
    echo "Creating placeholder man page..."
    cat > man/man1/{{ package_name }}.1 << EOF
.TH {{ package_name | upper }} 1 "$(date +"%B %Y")" "{{ package_name }} manual"
.SH NAME
{{ package_name }} \- {{ description }}
.SH SYNOPSIS
.B {{ package_name }}
[\fIOPTIONS\fR] [\fICOMMAND\fR]
.SH DESCRIPTION
{{ description }}
.SH OPTIONS
.TP
.BR \-h ", " \-\-help
Show help message
.TP
.BR \-v ", " \-\-version
Show version information
.SH AUTHORS
{{ author_name }} <{{ author_email }}>
.SH COPYRIGHT
Copyright (C) {{ year }} {{ author_name }}
EOF
}

# Compress the man page
if [ -f "man/man1/{{ package_name }}.1" ]; then
    gzip -f man/man1/{{ package_name }}.1
    echo "✅ Man page generated in man/man1/{{ package_name }}.1.gz"
else
    echo "❌ Failed to generate man page"
    exit 1
fi